{
  "name": "needypet-care-tracker",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config drizzle-pg.config.ts",
    "db:migrate:pg": "drizzle-kit migrate --config drizzle-pg.config.ts",
    "db:seed": "tsx server/db/seed.ts",
    "db:import": "tsx server/db/import-legacy.ts"
  },
  "dependencies": {
    "@fontsource/comfortaa": "^5.2.8",
    "@lucide/vue": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "postgres": "^3.4.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@vite-pwa/nuxt": "^1.1.1",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  }
}
